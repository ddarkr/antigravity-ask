{
  "name": "antigravity-ask",
  "version": "0.2.9",
  "description": "CLI and shared client utilities for Antigravity chat automation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddarkr/antigravity-ask.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ddarkr/antigravity-ask",
  "bugs": {
    "url": "https://github.com/ddarkr/antigravity-ask/issues"
  },
  "keywords": [
    "antigravity",
    "cli",
    "automation",
    "agent",
    "bridge"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "antigravity-ask": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.4"
  }
}
