{
  "name": "antigravity-bridge-extension",
  "displayName": "Antigravity Ask Bridge",
  "description": "Automate Antigravity IDE — REST API and the antigravity-ask CLI for coding agents",
  "version": "0.2.16",
  "publisher": "ddarkr",
  "license": "MIT",
  "preview": true,
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddarkr/antigravity-ask.git",
    "directory": "packages/extension"
  },
  "homepage": "https://github.com/ddarkr/antigravity-ask",
  "bugs": {
    "url": "https://github.com/ddarkr/antigravity-ask/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "bridge",
    "agents",
    "automation",
    "chat"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-bridge.start",
        "title": "Antigravity Ask Bridge: Show Server Status"
      },
      {
        "command": "antigravity-bridge.toggle",
        "title": "Antigravity Ask Bridge: Show Bridge Settings Info"
      }
    ],
    "configuration": {
      "title": "Antigravity Ask Bridge",
      "properties": {
        "antigravity-bridge.httpPort": {
          "type": "number",
          "default": 5820,
          "description": "HTTP server port used when the bridge is enabled and the window activates"
        },
        "antigravity-bridge.wsPort": {
          "type": "number",
          "default": 5821,
          "description": "WebSocket server port used when the bridge is enabled and the window activates"
        },
        "antigravity-bridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Antigravity Ask Bridge server when the extension activates"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "esbuild src/extension.ts --bundle --outdir=dist --platform=node --format=cjs --external:vscode --sourcemap",
    "watch": "pnpm build --watch",
    "package": "npx -y @vscode/vsce package --no-dependencies",
    "package:ci": "npx -y @vscode/vsce package --no-dependencies --out antigravity-bridge-extension.vsix",
    "publish:vsce": "npx -y @vscode/vsce publish --packagePath antigravity-bridge-extension.vsix",
    "publish:ovsx": "npx -y ovsx publish antigravity-bridge-extension.vsix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "antigravity-ask": "workspace:*",
    "antigravity-sdk": "^1.7.0",
    "hono": "^4.7.0",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  }
}
